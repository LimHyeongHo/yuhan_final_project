<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <!-- Spring Boot's default logging formats -->
    <include resource="org/springframework/boot/logging/logback/defaults.xml"/>
    <include resource="org/springframework/boot/logging/logback/console-appender.xml"/>

    <!-- 1. 기본 콘솔 출력 설정 -->
    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
    </root>

    <!-- 2. 실무용 관리자 액션 로그용 별도 파일 (admin-actions.log) -->
    <appender name="ADMIN_LOG_FILE" class="ch.qos.logback.core.FileAppender">
        <file>logs/admin-actions.log</file>
        <!-- 내용 추가 방식 (이어쓰기) -->
        <append>true</append> 
        <encoder>
            <!-- ex) 2026.04.01 15:39 시나리오B 관리자액션... 형식 지정 -->
            <pattern>%d{yyyy.MM.dd HH:mm} %msg%n</pattern>
        </encoder>
    </appender>

    <!-- 3. logger 설정 (AdminActionLogger라는 이름의 로거 호출 시에만 동작) -->
    <!-- additivity="true"로 하면 콘솔에도 출력되고, 파일에도 출력됩니다 -->
    <logger name="AdminActionLogger" level="INFO" additivity="true">
        <appender-ref ref="ADMIN_LOG_FILE"/>
    </logger>

</configuration>
